{
  "name": "tsp-takapay",
  "version": "1.0.0",
  "description": "Token Service Provider (TSP) - TakaPay Postman test collections",
  "scripts": {
    "test": "newman run TSP_TestCases_postman_collection.json --bail",
    "test:happy-path": "newman run TSP.postman_collection.json --bail",
    "test:emvco": "newman run TSP_EMVCo_TestCases_postman_collection.json --bail",
    "test:automated": "newman run TSP_Automated_TestSuite_postman_collection.json -e TSP_TakaPay_environment.json",
    "test:automated:report": "newman run TSP_Automated_TestSuite_postman_collection.json -e TSP_TakaPay_environment.json -r htmlextra --reporter-htmlextra-export reports/automated-report.html",
    "test:combined": "newman run TSP_Combined_Automated_postman_collection.json -e TSP_TakaPay_environment.json",
    "test:combined:report": "newman run TSP_Combined_Automated_postman_collection.json -e TSP_TakaPay_environment.json -r htmlextra --reporter-htmlextra-export reports/combined-report.html",
    "test:html-report": "newman run TSP_TestCases_postman_collection.json -r htmlextra --reporter-htmlextra-export reports/test-report.html",
    "generate": "node scripts/generate-test-cases.js",
    "generate:automated": "node scripts/generate-automated-collection.js",
    "generate:combined": "node scripts/generate-combined-collection.js",
    "generate:final": "node scripts/generate-final-collection.js",
    "test:final": "newman run TSP_Final_Automated_postman_collection.json -e TSP_TakaPay_environment.json",
    "test:final:report": "newman run TSP_Final_Automated_postman_collection.json -e TSP_TakaPay_environment.json -r htmlextra --reporter-htmlextra-export reports/final-report.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rano5604/TSP-TakaPay.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rano5604/TSP-TakaPay/issues"
  },
  "homepage": "https://github.com/rano5604/TSP-TakaPay#readme",
  "devDependencies": {
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}
